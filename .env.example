# Copy to ".env" for `docker compose up`. All values have safe local defaults
# in docker-compose.yml — override here for anything real. DO NOT commit .env.

# --- Postgres ---
POSTGRES_USER=pwuser
POSTGRES_PASSWORD=pwpass
POSTGRES_DB=personalwebsite

# --- API ---
# Must be >= 32 chars (HMAC-SHA256 signing key)
JWT_KEY=change-me-to-a-long-random-secret-at-least-32-chars
ADMIN_EMAIL=danilo@neumannmarques.com
ADMIN_PASSWORD=ChangeMe123!

# --- Cloudflare R2 (optional locally; required for asset uploads) ---
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- Web (build-time) ---
# Empty = relative /api calls (same-origin via the Caddy proxy on :8080).
VITE_API_URL=
# Where the web container forwards /api to (Nitro proxy) when hit directly on :4000.
API_PROXY_TARGET=http://api:8080
